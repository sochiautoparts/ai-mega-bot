# === Обязательные настройки ===

# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# API ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# ID администраторов (через запятую, узнать у @userinfobot)
ADMIN_IDS=123456789

# === Настройки AI ===

# Модель для чата (gpt-4o-mini — дешёвая и быстрая)
OPENAI_MODEL=gpt-4o-mini

# Модель для генерации картинок
OPENAI_IMAGE_MODEL=dall-e-3

# === Лимиты бесплатного плана ===
FREE_CHAT_LIMIT=5
FREE_IMAGE_LIMIT=2
FREE_COPYWRITE_LIMIT=3

# Дней Pro при регистрации (триал)
TRIAL_PRO_DAYS=3

# === Цены в Telegram Stars ===
# 1 Star ≈ $0.01
# 250 Stars ≈ $2.50/мес
PRICE_STARS_MONTH=250
PRICE_STARS_3MONTH=600
PRICE_STARS_YEAR=2000

# === Реферальная система ===
# Дней Pro за каждого приглашённого друга
REFERRAL_BONUS_DAYS=3

# === Дополнительно ===
# Канал бота (для проверки подписки, без @)
CHANNEL_USERNAME=
# Путь к базе данных
DB_PATH=bot_database.db
